# ──────────────────────────────────────────────────────────────────────────────
# AutoDev Backend — Environment Variables
# Copy this file to .env and fill in real values before running.
# ──────────────────────────────────────────────────────────────────────────────

# ──── Server ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000

# ──── Clerk Authentication ────────────────────────────────────────────────────
# From https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key

# ──── AWS Configuration ───────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ──── DynamoDB Tables ─────────────────────────────────────────────────────────
# Optional: prefix for table names (useful for staging vs prod)
DYNAMODB_TABLE_PREFIX=autodev-

# Table names (without prefix — the app prepends DYNAMODB_TABLE_PREFIX)
USERS_TABLE=users
REPOS_TABLE=repos
ANALYSIS_TABLE=analysis
QA_CACHE_TABLE=qa-cache
PROGRESS_TABLE=progress

# ──── S3 ──────────────────────────────────────────────────────────────────────
S3_BUCKET=autodev-codebase-indexes
