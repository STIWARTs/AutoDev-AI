# ══════════════════════════════════════════════════════════════════════════════
# AutoDev Backend — Environment Variables
# Copy this file to .env and fill in your values before starting the server.
# ══════════════════════════════════════════════════════════════════════════════

# ──── Server ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000        # Change to your prod frontend URL

# ──── Clerk Authentication ─────────────────────────────────────────────────────
# From: https://dashboard.clerk.com → Your App → API Keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ══════════════════════════════════════════════════════════════════════════════
# AWS — Required for all AI analysis, storage, and database features
# ══════════════════════════════════════════════════════════════════════════════
# From: https://console.aws.amazon.com/iam → Users → Your User → Security credentials
# Minimum IAM permissions needed:
#   - bedrock:InvokeModel          (for Claude + Titan Embeddings)
#   - dynamodb:GetItem, PutItem, Query, Scan, UpdateItem
#   - s3:GetObject, PutObject, ListBucket
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ──── AWS Bedrock Models ────────────────────────────────────────────────────────
# These models must be enabled in your AWS account:
# https://console.aws.amazon.com/bedrock → Model access → Request access
# Claude 3.5 Sonnet v2  → architecture analysis, walkthroughs, Q&A
# Claude 3 Haiku         → i18n translation, quick tasks
# Titan Embeddings v2    → semantic search
#
# Default model IDs (already hardcoded, listed here for reference):
#   CLAUDE_SONNET = anthropic.claude-3-5-sonnet-20241022-v2:0
#   CLAUDE_HAIKU  = anthropic.claude-3-haiku-20240307-v1:0
#   TITAN_EMBED   = amazon.titan-embed-text-v2:0
#
# Override only if you want to pin different versions:
# BEDROCK_SONNET_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# BEDROCK_HAIKU_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# ──── S3 Bucket ────────────────────────────────────────────────────────────────
# Create at: https://console.aws.amazon.com/s3 → Create bucket
# Stores raw code indexes and analysis outputs
S3_BUCKET=autodev-codebase-indexes

# ──── DynamoDB Tables ──────────────────────────────────────────────────────────
# Create at: https://console.aws.amazon.com/dynamodb → Create table
# Each table uses "repoId" (String) as partition key, "userId" (String) as sort key
# (except qa-cache which uses "cacheKey" as partition key only)
USERS_TABLE=autodev-users
REPOS_TABLE=autodev-repos
ANALYSIS_TABLE=autodev-analysis
QA_CACHE_TABLE=autodev-qa-cache
PROGRESS_TABLE=autodev-progress

# ──── GitHub Token (for manual repo ingestion) ─────────────────────────────────
# Required when triggering analysis manually via API (without the GitHub App).
# From: https://github.com/settings/tokens → Generate new token (classic)
# Scopes needed: repo (full), read:org
# Leave blank if you're using the GitHub App webhook flow instead.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
