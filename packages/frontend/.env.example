# ──────────────────────────────────────────────────────────────────────────────
# AutoDev Frontend — Environment Variables
# Copy this file to .env.local and fill in real values before running.
# ──────────────────────────────────────────────────────────────────────────────

# ──── Clerk Authentication ────────────────────────────────────────────────────
# From https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key

# Clerk routing (do not change unless you rename the sign-in/up pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ──── Backend API ─────────────────────────────────────────────────────────────
# URL of the AutoDev backend (used by API utility functions)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ──── GitHub App ──────────────────────────────────────────────────────────────
# Install URL for your GitHub App — users are redirected here to connect repos
# Format: https://github.com/apps/<app-slug>/installations/new
NEXT_PUBLIC_GITHUB_APP_INSTALL_URL=https://github.com/apps/autodev-io/installations/new
