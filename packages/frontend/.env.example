# ══════════════════════════════════════════════════════════════════════════════
# AutoDev Frontend — Environment Variables
# Copy this file to .env.local and fill in your values before running Next.js.
# ══════════════════════════════════════════════════════════════════════════════

# ──── Backend API ──────────────────────────────────────────────────────────────
# URL of the AutoDev backend server
# Local dev: http://localhost:3001/api
# Production: https://your-api.amazonaws.com/prod/api  (or your domain)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ──── Clerk Authentication ─────────────────────────────────────────────────────
# From: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk routing — leave as-is unless you rename these pages
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ──── GitHub App ───────────────────────────────────────────────────────────────
# Install URL for your GitHub App — users click this to connect their repos.
# From: https://github.com/settings/apps → Your App → Public Link
# Format: https://github.com/apps/<your-app-slug>/installations/new
NEXT_PUBLIC_GITHUB_APP_INSTALL_URL=https://github.com/apps/your-autodev-app/installations/new
