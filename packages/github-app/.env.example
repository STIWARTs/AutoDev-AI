# ══════════════════════════════════════════════════════════════════════════════
# AutoDev GitHub App — Environment Variables (Probot)
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════
# How to get these values:
# 1. Go to https://github.com/settings/apps → New GitHub App
# 2. Fill in: Name, Homepage URL, Webhook URL (your ngrok/prod URL + /api/github/events)
# 3. Set Webhook Secret (any random string — also used below)
# 4. Permissions: Repository contents (read), Pull requests (read+write), Metadata (read)
# 5. Events: Installation, Push, Pull request
# 6. Create App → you'll land on the settings page with all values below

# ──── GitHub App Credentials ───────────────────────────────────────────────────
# From: GitHub App settings page → General tab
APP_ID=123456

# Generate at: GitHub App settings → General → Private keys → Generate a private key
# Paste the entire contents of the downloaded .pem file (keep newlines as \n)
PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAK...\n-----END RSA PRIVATE KEY-----"

# The secret you set when creating the app under "Webhook secret"
WEBHOOK_SECRET=your_webhook_secret_here

# ──── OAuth (optional — for user login via GitHub) ────────────────────────────
# From: GitHub App settings → General → OAuth credentials
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──── Backend Connection ────────────────────────────────────────────────────────
# URL of the AutoDev backend — the GitHub App calls this after fetching repo content
# Local dev (with ngrok for GitHub → localhost): http://localhost:3001
BACKEND_URL=http://localhost:3001

# ──── App Public URL ───────────────────────────────────────────────────────────
# Used in PR comments to link users back to the dashboard
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──── Local Dev Tunnel ─────────────────────────────────────────────────────────
# GitHub webhooks must reach a public URL. For local dev, use smee.io or ngrok.
# smee.io (free):  npx smee -u https://smee.io/your-channel --target http://localhost:3000/api/github/events
# ngrok:           ngrok http 3000
# WEBHOOK_PROXY_URL=https://smee.io/your-channel-id
